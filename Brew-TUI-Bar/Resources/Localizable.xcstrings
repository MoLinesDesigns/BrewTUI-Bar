    "Brew-TUI-Bar %@ is out of sync with Brew-TUI %@. They must match for license decryption and updates.\n\nRun this in the terminal:\n\n  brew-tui install-brew-tui-bar --force": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Brew-TUI-Bar %1$@ is out of sync with Brew-TUI %2$@. They must match for license decryption and updates.\n\nRun this in the terminal:\n\n  brew-tui install-brew-tui-bar --force"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Brew-TUI-Bar %1$@ no coincide con Brew-TUI %2$@. Deben coincidir para descifrar la licencia y recibir actualizaciones.\n\nEjecuta en el terminal:\n\n  brew-tui install-brew-tui-bar --force"
          }
        }
      }
    },
