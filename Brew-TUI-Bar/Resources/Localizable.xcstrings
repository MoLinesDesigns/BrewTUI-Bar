    "%@": {
      "comment": "A label displaying the number of outdated packages. The argument is the count of outdated packages.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@"
          }
        }
      }
    },
    "%@ CVE": {
      "comment": "A label displaying the number of Critical, High, or Medium CVEs for a given package. The first argument is the name of a package. The second argument is the number of CVEs for that package.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ CVE"
          }
        }
      }
    },
